# Token del bot (Discord Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=

# Application ID (Discord Developer Portal > General Information > Application ID)
DISCORD_CLIENT_ID=

# URL base de tu panel Pterodactyl (sin barra al final)
PTERODACTYL_URL=https://mcpanel.gamehost.cl

# Tu API key de tipo Client (empieza con ptlc_)
PTERODACTYL_API_KEY=

# ID corto de tu servidor (lo que aparece en la URL: /server/XXXXXXXX)
SERVER_ID=c7fa539d
